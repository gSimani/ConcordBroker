{
  "name": "concordbroker-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:localhost": "cross-env VITE_ENV=localhost vite",
    "build": "vite build",
    "build:localhost": "cross-env VITE_ENV=localhost vite build",
    "build:analyze": "vite build && npx serve dist",
    "build:stats": "vite build --mode analyze",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "start:localhost": "cross-env VITE_ENV=localhost vite --host --port 5173",
    "perf:audit": "npx lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html",
    "perf:bundle": "npm run build && open dist/stats.html",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
