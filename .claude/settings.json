{
  "project": "concordbroker",
  "version": "1.0.0",
  "description": "ConcordBroker real estate investment platform",

  "inheritGlobal": {
    "enabled": true,
    "globalConfigPath": "~/.claude/config.json",
    "inheritAgents": true,
    "inheritWorkflows": true,
    "inheritHooks": true,
    "allowOverrides": true
  },

  "autoStart": {
    "enabled": true,
    "useGlobalAgents": true,
    "startupScript": "~/.claude/start-agents.cjs",
    "services": [
      {
        "name": "verification-agent",
        "source": "global",
        "enabled": true,
        "description": "Automatic code verification sub-agent from global config"
      }
    ]
  },

  "agents": {
    "verification-agent": {
      "source": "global",
      "autoStart": true,
      "useGlobalConfig": true,
      "localOverrides": {
        "watchDirectories": [
          "apps/web/src",
          "apps/api",
          "mcp-server"
        ]
      }
    },
    "property-update-agent": {
      "source": "local",
      "autoStart": false,
      "configFile": ".claude/agents/property-update-agent.json",
      "enabled": true,
      "priority": "high",
      "schedule": "daily",
      "description": "Daily Florida property data update system - monitors portal, downloads files, updates database"
    },
    "env-sync-agent": {
      "source": "local",
      "autoStart": true,
      "configFile": ".claude/agents/env-sync-agent.json",
      "enabled": true,
      "priority": "high",
      "description": "Environment Variable Synchronizer - Syncs .env files across all worktrees with encryption"
    },
    "code-quality-agent": {
      "source": "local",
      "autoStart": false,
      "configFile": ".claude/agents/code-quality-agent.json",
      "enabled": true,
      "priority": "high",
      "description": "Code Quality Gate - Runs linting, type-checking, and auto-fixes before commits"
    },
    "auto-commit-agent": {
      "source": "local",
      "autoStart": false,
      "configFile": ".claude/agents/auto-commit-agent.json",
      "enabled": true,
      "priority": "medium",
      "description": "Auto-Commit & Sync - Automatically commits changes with AI-generated messages every 30 minutes"
    }
  },

  "hooks": {
    "enabled": true,
    "useGlobalHooks": true,
    "postChange": {
      "enabled": true,
      "source": "global",
      "agents": ["env-sync-agent", "code-quality-agent"]
    },
    "postSave": {
      "enabled": true,
      "agents": ["auto-commit-agent"],
      "description": "Track file saves for auto-commit interval"
    },
    "preCommit": {
      "enabled": true,
      "agents": ["code-quality-agent"],
      "blocking": true,
      "description": "Run quality checks with auto-fix before allowing commit"
    },
    "prePush": {
      "enabled": true,
      "agents": ["code-quality-agent"],
      "blocking": true,
      "description": "Run quality checks before allowing push"
    },
    "preSwitch": {
      "enabled": true,
      "agents": ["auto-commit-agent"],
      "blocking": true,
      "description": "Commit and push before switching branches/worktrees"
    },
    "sessionEnd": {
      "enabled": true,
      "agents": ["auto-commit-agent"],
      "blocking": true,
      "description": "Commit and push before ending session"
    },
    "worktreeCreated": {
      "enabled": true,
      "agents": ["env-sync-agent"],
      "description": "Sync environment variables to new worktree"
    },
    "dependencyUpdate": {
      "enabled": true,
      "agents": ["env-sync-agent"],
      "description": "Re-sync env vars after dependency updates"
    }
  },

  "workflows": {
    "useGlobalWorkflows": true,
    "autoVerify": {
      "enabled": true,
      "source": "global"
    }
  },

  "features": {
    "automaticVerification": true,
    "fileWatching": true,
    "realtimeStatus": true,
    "verificationHistory": true,
    "useGlobalFeatures": true
  },

  "paths": {
    "logs": "logs",
    "status": "logs/verification-status.json",
    "history": "logs/verification-history.jsonl",
    "globalLogs": "~/.claude/logs"
  },

  "metadata": {
    "lastUpdated": "2025-11-09T00:00:00.000Z",
    "globalConfigVersion": "1.0.0",
    "agentOrchestration": {
      "version": "1.0.0",
      "agentsAdded": [
        "env-sync-agent",
        "code-quality-agent",
        "auto-commit-agent"
      ],
      "hooksConfigured": [
        "postChange",
        "postSave",
        "preCommit",
        "prePush",
        "preSwitch",
        "sessionEnd",
        "worktreeCreated",
        "dependencyUpdate"
      ]
    }
  }
}
