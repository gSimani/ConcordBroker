# ============================================
# CONCORDBROKER .gitignore
# ============================================

# Environment Variables - NEVER COMMIT THESE
.env
.env.local
.env.development
.env.production
.env.test
.env*.local

# Keep the example file
!.env.example

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
*.log

# Build outputs
dist/
build/
.next/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# Database
*.db
*.sqlite
*.sqlite3

# Data files (CSV, ZIP archives, large datasets)
*.csv
*.zip
data/
backups/
historical_data/
florida_property_data/
archive-cleanup-*/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp

# Redis dump
dump.rdb

# Vercel
.vercel

# Railway
railway.json
apps/api/nul
nul
