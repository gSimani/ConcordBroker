# ============================================
# CONCORDBROKER ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================

# ============================================
# DATABASE CONFIGURATION - SUPABASE POSTGRESQL
# ============================================
DATABASE_URL=postgres://postgres.PROJECT_ID:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x
POSTGRES_URL=postgres://postgres.PROJECT_ID:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x
POSTGRES_URL_NON_POOLING=postgres://postgres.PROJECT_ID:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_PRISMA_URL=postgres://postgres.PROJECT_ID:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=db.PROJECT_ID.supabase.co
POSTGRES_DATABASE=postgres

# ============================================
# SUPABASE CONFIGURATION
# ============================================
SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_KEY=your_anon_key_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here
SUPABASE_PROJECT_ID=your_project_id_here
SUPABASE_PROJECT_NAME=your_project_name_here
SUPABASE_PUBLISH_KEY=your_publish_key_here
SUPABASE_PUBLISH_SECRET_KEY=your_publish_secret_key_here

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_URL=https://PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# AI/LLM CONFIGURATION
# ============================================
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
CLAUDE_API_KEY=sk-ant-your_anthropic_api_key_here
HUGGINGFACE_API_TOKEN=hf_your_huggingface_token_here
HUGGINGFACE_WRITE_TOKEN=hf_your_huggingface_write_token_here
HUGGINGFACE_FINEGRAINED_TOKEN=hf_your_finegrained_token_here
HUGGINGFACE_ORG_NAME=Your Organization Name
HUGGINGFACE_WEBSITE=https://your-website.com

# ============================================
# LANGCHAIN/LANGSMITH CONFIGURATION
# ============================================
LANGCHAIN_API_KEY=lsv2_pt_your_langchain_api_key_here
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=your_project_name
LANGCHAIN_PROJECT=your_project_name
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================
# VERCEL DEPLOYMENT CONFIGURATION
# ============================================
VERCEL_API_TOKEN=your_vercel_api_token_here
VERCEL_PROJECT_ID=prj_your_project_id_here
VERCEL_PROJECT_NAME=your-project-name
VERCEL_DOMAIN=https://your-domain.com
VERCEL_ORG_ID=team_your_org_id_here
VERCEL_SCOPE=your-scope-here
VERCEL_TEAM=your-team-name
VERCEL_DASHBOARD_URL=https://vercel.com/your-team/your-project

# ============================================
# RAILWAY BACKEND CONFIGURATION
# ============================================
RAILWAY_API_TOKEN=your_railway_api_token_here
RAILWAY_PROJECT_ID=your_railway_project_id_here
RAILWAY_PROJECT_NAME=your-railway-project-name
RAILWAY_ENVIRONMENT=production
RAILWAY_INTERNAL_DOMAIN=your-project.railway.internal
RAILWAY_PUBLIC_DOMAIN=your-project.up.railway.app

# ============================================
# WEB SCRAPING & AUTOMATION
# ============================================
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key_here
E2B_API_KEY=e2b_your_e2b_api_key_here

# ============================================
# CACHING & PERFORMANCE - REDIS
# ============================================
REDIS_URL=redis://default:YOUR_PASSWORD@your-redis-host.redis-cloud.com:PORT
REDIS_HOST=your-redis-host.redis-cloud.com
REDIS_PORT=10062
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here
REDIS_CACHE_TTL_SEARCH=1800
REDIS_CACHE_TTL_AUTOCOMPLETE=7200
REDIS_CACHE_TTL_PROPERTY=3600
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_KEEPALIVE=true
REDIS_SOCKET_KEEPALIVE_OPTIONS=true
REDIS_HEALTH_CHECK_INTERVAL=30
CACHE_TTL=3600

# ============================================
# VERSION CONTROL
# ============================================
GITHUB_API_TOKEN=ghp_your_github_api_token_here
GITHUB_REPOSITORY=https://github.com/your-username/your-repo
GITHUB_BRANCH=main

# ============================================
# MCP SERVER CONFIGURATION
# ============================================
MCP_API_KEY=your-mcp-api-key-here
MCP_PORT=3001
MCP_HEALTH_ENDPOINT=http://localhost:3001/health

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=development
ENVIRONMENT=development
WEBSITE_URL=https://your-website.com
ACCESS_TOKEN_EXPIRY=3600
MAX_ROWS=1000

# ============================================
# UI FIELD VALIDATION CONFIGURATION
# ============================================
VALIDATION_TARGET_URL=https://your-website.com
VALIDATION_STAGING_URL=https://your-staging.vercel.app
VALIDATION_OUTPUT_DIR=./validation_reports
VALIDATION_MAX_PAGES=500
VALIDATION_CRAWL_DEPTH=3
VALIDATION_FUZZY_THRESHOLD=85

# ============================================
# LANGGRAPH WORKFLOW CONFIGURATION
# ============================================
WORKFLOW_MAX_RETRIES=3
WORKFLOW_TIMEOUT=300
ENABLE_STREAMING=true
ENABLE_HUMAN_IN_LOOP=false
DEFAULT_LLM_MODEL=gpt-4o-mini

# ============================================
# GETTING STARTED
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys and credentials
# 3. Ensure .env is in your .gitignore file
# 4. NEVER commit .env to version control
# 
# API Key Sources:
# - Supabase: https://app.supabase.com/project/[project-id]/settings/api
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/settings/keys
# - HuggingFace: https://huggingface.co/settings/tokens
# - LangSmith: https://smith.langchain.com/settings
# - Google Maps: https://console.cloud.google.com/apis/credentials
# - Vercel: https://vercel.com/account/tokens
# - Railway: https://railway.app/account/tokens
# - GitHub: https://github.com/settings/tokens
